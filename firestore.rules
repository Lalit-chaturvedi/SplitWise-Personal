rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Groups ────────────────────────────────────────────────
    match /groups/{groupId} {
      // Read: only members
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // Create: any authenticated user
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;

      // Update: only members (for joining, adding expenses, settling)
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || request.auth.uid in request.resource.data.memberIds);

      // Delete: only admin (group creator)
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      // ── Expenses ─────────────────────────────────────────────
      match /expenses/{expenseId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.paidBy
              || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy);
      }
    }
  }
}
